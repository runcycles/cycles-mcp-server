CYCLES_API_KEY=your-api-key-here
CYCLES_BASE_URL=https://api.runcycles.io
# DANGER: true disables live budget enforcement and returns synthetic allow/committed responses.
CYCLES_MOCK=false
# Required only to deliberately run mock mode with NODE_ENV=production.
CYCLES_ALLOW_MOCK_IN_PRODUCTION=false
PORT=3000
# HOST=127.0.0.1
# Optional bearer token required by every /mcp HTTP request when set.
# MCP_HTTP_AUTH_TOKEN=replace-with-a-long-random-token
